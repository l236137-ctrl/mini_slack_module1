# Copy this file to .env and fill in real values.
# NEVER commit the real .env file.

# Django
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://mini_slack:mini_slack@localhost:5432/mini_slack

# Which settings module to use: mini_slack.settings.dev | mini_slack.settings.prod
DJANGO_SETTINGS_MODULE=mini_slack.settings.dev

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7
